        <mxCell id="modelu" value="model_usage" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#1D6638;fontSize=11;fontColor=#16191F;align=center;" vertex="1" parent="1">
          <mxGeometry x="290" y="460" width="140" height="60" as="geometry" />
        </mxCell>
        <mxCell id="students" value="students&#10;(실명 매핑 + 로그인)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#1D6638;fontSize=11;fontColor=#16191F;align=center;" vertex="1" parent="1">
          <mxGeometry x="460" y="460" width="180" height="60" as="geometry" />
        </mxCell>
        <mxCell id="schools-t" value="schools" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#1D6638;fontSize=11;fontColor=#16191F;align=center;" vertex="1" parent="1">
          <mxGeometry x="670" y="460" width="110" height="60" as="geometry" />
        </mxCell>
        <mxCell id="ingest-runs" value="ingest_runs&#10;audit_log" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#1D6638;fontSize=11;fontColor=#16191F;align=center;" vertex="1" parent="1">
          <mxGeometry x="810" y="460" width="140" height="60" as="geometry" />
        </mxCell>
        <mxCell id="admins" value="admins&#10;(RBAC)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#1D6638;fontSize=11;fontColor=#16191F;align=center;" vertex="1" parent="1">
          <mxGeometry x="980" y="460" width="140" height="60" as="geometry" />
        </mxCell>

        <!-- 화살표: daily_usage → snapshot 계산 -->
        <mxCell id="arr-du-snap" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeColor=#1D6638;strokeWidth=2;endArrow=block;endFill=1;" edge="1" parent="1" source="daily" target="snap-band">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ───────── Layer 4: Snapshot cache ───────── -->
        <mxCell id="snap-band" value="④ 스냅샷 캐시 — computeAndStoreSnapshots() 인제스트 직후 1회 (이번 달 매일, 지난 달 월초 1회)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF3EB;strokeColor=#EC7211;fontSize=11;fontStyle=1;fontColor=#7A3A00;align=left;verticalAlign=top;spacingLeft=12;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="40" y="580" width="1120" height="120" as="geometry" />
        </mxCell>

        <mxCell id="rank-snap" value="ranking_snapshot&#10;(period × metric × school)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#EC7211;fontSize=11;fontColor=#16191F;align=center;" vertex="1" parent="1">
          <mxGeometry x="120" y="620" width="220" height="60" as="geometry" />
        </mxCell>
        <mxCell id="kpi-snap" value="kpi_snapshot&#10;(단일 행)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#EC7211;fontSize=11;fontColor=#16191F;align=center;" vertex="1" parent="1">
          <mxGeometry x="380" y="620" width="180" height="60" as="geometry" />
        </mxCell>
        <mxCell id="champ-snap" value="monthly_champion_snapshot&#10;(metric × school × 12개월)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#EC7211;fontSize=11;fontColor=#16191F;align=center;" vertex="1" parent="1">
          <mxGeometry x="600" y="620" width="240" height="60" as="geometry" />
        </mxCell>
        <mxCell id="snap-note" value="페이지가 읽을 결과만 미리 계산해 저장.&#10;클라이언트 부담 0 — SELECT 한 줄로 끝." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fontColor=#7A3A00;" vertex="1" parent="1">
          <mxGeometry x="870" y="625" width="270" height="50" as="geometry" />
        </mxCell>

        <!-- 화살표: snapshot → Next.js -->
        <mxCell id="arr-snap-next" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeColor=#EC7211;strokeWidth=2;endArrow=block;endFill=1;" edge="1" parent="1" source="snap-band" target="next-band">
          <mxGeometry relative="1" as="geometry" />
