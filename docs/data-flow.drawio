        <!-- ───────── User ───────── -->
        <mxCell id="user" value="⑥ 브라우저 — 학생 / 어드민&#10;마스킹된 랭킹 / 본인 순위 / 본교 비교 차트" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#232F3E;strokeColor=#161E2D;fontSize=12;fontStyle=1;fontColor=#FFFFFF;align=center;" vertex="1" parent="1">
          <mxGeometry x="380" y="870" width="440" height="50" as="geometry" />
