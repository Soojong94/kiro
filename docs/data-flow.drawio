        <!-- ───────── Layer 5: Next.js ───────── -->
        <mxCell id="next-band" value="⑤ Next.js SSR — 페이지 요청 시 스냅샷 SELECT → HTML 응답" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F2F8FD;strokeColor=#0972D3;fontSize=11;fontStyle=1;fontColor=#033160;align=left;verticalAlign=top;spacingLeft=12;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="40" y="740" width="1120" height="100" as="geometry" />
