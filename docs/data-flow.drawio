        <mxCell id="daily" value="daily_usage&#10;(date+school+user+client)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#1D6638;fontSize=11;fontColor=#16191F;align=center;" vertex="1" parent="1">
          <mxGeometry x="80" y="460" width="180" height="60" as="geometry" />
