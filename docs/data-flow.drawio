<mxfile host="app.diagrams.net" agent="hand" version="24.0.0">
  <diagram id="kiro-flow" name="Kiro 데이터 흐름">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- ───────── 타이틀 ───────── -->
        <mxCell id="title" value="Kiro 통합 랭킹 — 데이터 흐름" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=22;fontStyle=1;fontColor=#16191F;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="1120" height="34" as="geometry" />
        </mxCell>
        <mxCell id="subtitle" value="여러 조직의 S3 → 인제스트 → DB 누적 → 스냅샷 캐시 → 페이지" style="text;html=1;strokeColor=none;fillColor=none;align=center;whiteSpace=wrap;fontSize=12;fontColor=#5F6B7A;" vertex="1" parent="1">
          <mxGeometry x="40" y="56" width="1120" height="20" as="geometry" />
        </mxCell>

        <!-- ───────── Layer 1: S3 buckets ───────── -->
        <mxCell id="s3-band" value="① 학교별 AWS 계정의 S3 버킷 (Kiro 가 매일 02:00 UTC CSV 떨굼)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F2F8FD;strokeColor=#0972D3;fontSize=11;fontStyle=1;fontColor=#033160;align=left;verticalAlign=top;spacingLeft=12;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="40" y="100" width="1120" height="140" as="geometry" />
        </mxCell>

        <mxCell id="s3-1" value="School A S3&#10;(자기 계정)" style="shape=mxgraph.aws4.bucket;sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#7AA116;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=11;fontStyle=1;aspect=fixed;shadow=0;labelPosition=center;" vertex="1" parent="1">
          <mxGeometry x="100" y="140" width="78" height="78" as="geometry" />
        </mxCell>
        <mxCell id="s3-2" value="School B S3" style="shape=mxgraph.aws4.bucket;sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#7AA116;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=11;fontStyle=1;aspect=fixed;" vertex="1" parent="1">
          <mxGeometry x="280" y="140" width="78" height="78" as="geometry" />
        </mxCell>
        <mxCell id="s3-3" value="School C S3" style="shape=mxgraph.aws4.bucket;sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#7AA116;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=11;fontStyle=1;aspect=fixed;" vertex="1" parent="1">
          <mxGeometry x="460" y="140" width="78" height="78" as="geometry" />
        </mxCell>
        <mxCell id="s3-dot" value="…" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=24;fontColor=#5F6B7A;" vertex="1" parent="1">
          <mxGeometry x="600" y="155" width="60" height="60" as="geometry" />
        </mxCell>
        <mxCell id="s3-n" value="School N S3" style="shape=mxgraph.aws4.bucket;sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#7AA116;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=11;fontStyle=1;aspect=fixed;" vertex="1" parent="1">
          <mxGeometry x="720" y="140" width="78" height="78" as="geometry" />
        </mxCell>

        <mxCell id="s3-note" value="cross-account 접근: 버킷 정책 또는 STS AssumeRole&#10;매일 02:00 UTC, 학교별 CSV 한 벌" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fontColor=#5F6B7A;" vertex="1" parent="1">
          <mxGeometry x="840" y="155" width="300" height="40" as="geometry" />
        </mxCell>

        <!-- 화살표: S3 → ingest -->
        <mxCell id="arr-s3-ingest" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeColor=#0972D3;strokeWidth=2;endArrow=block;endFill=1;" edge="1" parent="1" source="s3-band" target="ingest">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ───────── Layer 2: Ingest worker ───────── -->
        <mxCell id="ingest" value="② Ingest Worker (cron, 매일 02:30 UTC)&#10;&#10;downloadCsvFiles → parseCsv → UPSERT daily_usage&#10;실행 결과는 ingest_runs 에 학교별 기록" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF3EB;strokeColor=#EC7211;fontSize=12;fontStyle=1;fontColor=#7A3A00;align=left;verticalAlign=top;spacingLeft=14;spacingTop=10;" vertex="1" parent="1">
          <mxGeometry x="380" y="280" width="440" height="100" as="geometry" />
        </mxCell>

        <!-- 화살표: ingest → daily_usage -->
        <mxCell id="arr-ingest-du" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeColor=#EC7211;strokeWidth=2;endArrow=block;endFill=1;" edge="1" parent="1" source="ingest" target="daily">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ───────── Layer 3: DB raw ───────── -->
        <mxCell id="db-band" value="③ PostgreSQL — 원천 데이터 (영구 누적, UPSERT 만)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F1F8F5;strokeColor=#1D6638;fontSize=11;fontStyle=1;fontColor=#1D6638;align=left;verticalAlign=top;spacingLeft=12;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="40" y="420" width="1120" height="120" as="geometry" />
