        <mxCell id="page-public" value="/&#10;공개 랭킹" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#0972D3;fontSize=11;fontColor=#16191F;align=center;" vertex="1" parent="1">
          <mxGeometry x="100" y="775" width="140" height="55" as="geometry" />
        </mxCell>
        <mxCell id="page-champ" value="/champions&#10;월별 챔피언" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#0972D3;fontSize=11;fontColor=#16191F;align=center;" vertex="1" parent="1">
          <mxGeometry x="270" y="775" width="140" height="55" as="geometry" />
        </mxCell>
        <mxCell id="page-admin" value="/admin&#10;운영 대시보드" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#0972D3;fontSize=11;fontColor=#16191F;align=center;" vertex="1" parent="1">
          <mxGeometry x="440" y="775" width="140" height="55" as="geometry" />
        </mxCell>
        <mxCell id="auth" value="iron-session 쿠키&#10;학생 / 어드민 분리" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#0972D3;fontSize=11;fontColor=#16191F;align=center;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="640" y="775" width="180" height="55" as="geometry" />
        </mxCell>
        <mxCell id="nginx" value="nginx + Let's Encrypt&#10;https://kiro.tbit.co.kr" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#0972D3;fontSize=11;fontColor=#16191F;align=center;" vertex="1" parent="1">
          <mxGeometry x="860" y="775" width="220" height="55" as="geometry" />
        </mxCell>

        <!-- 화살표: Next.js → 사용자 -->
        <mxCell id="arr-next-user" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeColor=#0972D3;strokeWidth=2;endArrow=block;endFill=1;" edge="1" parent="1" source="next-band" target="user">
          <mxGeometry relative="1" as="geometry" />
