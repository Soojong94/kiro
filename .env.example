# Kiro 통합 랭킹 대시보드 — 환경변수 통합 템플릿
#
# 이 파일은 커밋되며, 실제 값은 별도 파일에 작성 (gitignore 됨):
#   - 로컬 개발:  .env.local
#   - 운영 서버:  .env
#
# 두 환경에서 다르게 채워야 하는 키는 [LOCAL] / [PROD] 표시로 안내.
# 같은 값이어도 무방한 키는 양쪽에 동일하게 넣어도 됨.

# ── DB ────────────────────────────────────────────────────────────
# [LOCAL] 호스트 머신에서 컨테이너 Postgres 로 접속
DATABASE_URL=postgres://kiro:kiro_dev_pw@127.0.0.1:5432/kiro

# [PROD] docker-compose 가 ${DB_PASSWORD} 로 DATABASE_URL 자동 조립
#        로컬에선 불필요, 서버 .env 에만 필요
DB_PASSWORD=CHANGE_ME_DB_PASSWORD

# ── 어드민 부트스트랩 ──────────────────────────────────────────────
# `npm run bootstrap-admin` 1회 실행해 super 어드민 생성 후 즉시 제거 권장
ADMIN_BOOTSTRAP_PASSWORD=CHANGE_ME_ADMIN_PASSWORD

# ── 세션 ──────────────────────────────────────────────────────────
# iron-session 쿠키 암호화 비밀. 32자 이상 랜덤.
# 생성 예: openssl rand -base64 32
# 한번 정하면 바꾸지 말 것 (바꾸면 모든 세션 무효화)
SESSION_COOKIE_PASSWORD=CHANGE_ME_32CHARS_OR_MORE

# [LOCAL] HTTP 로 로컬 테스트할 때만 활성화 (쿠키 secure 플래그 끔)
# [PROD] 절대 켜지 말 것 — HTTPS 강제 필요
# SESSION_COOKIE_INSECURE=1

# ── 이메일 (AWS SES) ──────────────────────────────────────────────
# 학생 비번 재설정 / 운영 cron 알림 발송용. SES 자격증명은 AWS IAM (아래) 사용.
# SES_REGION 은 SES 도메인 verify 한 region — 보통 AWS_REGION 과 다를 수 있음.
EMAIL_FROM="Kiro 통합 랭킹 <kiro@tbit.co.kr>"
SES_REGION=us-east-1

# 비번 재설정 메일에 들어갈 base URL
# [LOCAL] http://localhost:3000
# [PROD]  https://kiro.tbit.co.kr
APP_BASE_URL=http://localhost:3000

# ── AWS (S3 인제스트 + Identity Center 동기화 + SES 발송) ─────────
# [PROD] EC2 instance profile 권장 — AWS_ACCESS_KEY_ID/SECRET 비워둠.
# [LOCAL] 로컬 개발은 IAM 사용자 키 발급해서 채움.
# 학교별 S3 bucket / role_arn 은 환경변수가 아닌 DB(connections 테이블)에 저장.
AWS_REGION=ap-northeast-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── 기타 ──────────────────────────────────────────────────────────
TZ=Asia/Seoul

# ── 인제스트 ──────────────────────────────────────────────────────
# S3 CSV 원본을 호스트에 보관할 기간 (일). 기본 365.
# ARCHIVE_RETENTION_DAYS=365
