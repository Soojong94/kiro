# Kiro 학교 통합 랭킹 대시보드 — 환경변수 템플릿
# 이 파일은 커밋되며, 실제 값은 서버의 `.env.local` 에 별도 작성 (gitignore 됨).

# ── DB ──────────────────────────────────────────────────────────────
DATABASE_URL=postgres://kiro:CHANGE_ME@127.0.0.1:5432/kiro

# ── AWS (학교 S3 버킷에서 Kiro CSV 끌어오기) ─────────────────────────
# 가능하면 EC2 instance profile + STS AssumeRole 로 대체 (키 직접 저장 비권장).
AWS_REGION=ap-northeast-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# 학교별 S3 bucket / role_arn 등은 환경변수가 아닌 DB(`schools` 테이블)에 저장.

# ── 사내 어드민 인증 ────────────────────────────────────────────────
# iron-session 쿠키 암호화 비밀. 32자 이상 무작위 문자열.
SESSION_COOKIE_PASSWORD=
# 최초 어드민 계정 생성 시 1회만 사용. 생성 후 즉시 환경변수에서 제거.
ADMIN_BOOTSTRAP_PASSWORD=

# ── 기타 ────────────────────────────────────────────────────────────
TZ=Asia/Seoul
